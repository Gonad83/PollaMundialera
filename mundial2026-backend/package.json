{
  "name": "mundial2026-backend",
  "version": "1.0.0",
  "description": "API backend para la polla del Mundial 2026",
  "main": "src/index.js",
  "scripts": {
    "build": "npx prisma generate && npx prisma db push --accept-data-loss",
    "dev": "nodemon src/index.js",
